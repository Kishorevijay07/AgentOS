# Copy this file to `.env` and fill in your key. `.env` is gitignored — never
# commit real keys (and never put a real key in this example file).

# Required: your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Optional: which model to route to (any OpenRouter model id).
# Default: openai/gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini
